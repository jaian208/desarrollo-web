<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'añadir Juego', pageCSS: 'edicion' }) %>

<body class="bg-dark text-light">

<%- include("../partials/navbar") %>

<div class="container mt-5 pt-4 mb-5">
    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="edit-card shadow-lg">

                <!-- HEADER -->
                <div class="edit-header text-center">
                    <h2 class="fw-bold">Añadir Juego al Arsenal</h2>
                    <p class="text-white-50 small">Publica un nuevo título en GameZone</p>
                </div>

                <!-- BODY -->
                <div class="p-4">
                    <div class="preview-box mb-4 text-center">
                        <img src="/images/default-game.png"
                             id="previewImg"
                             class="preview-img">
                    </div>
                    <form action="/formulario"
                          method="POST"
                          enctype="multipart/form-data">

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="nombre" class="form-label text-white-50">
                                    Título del Juego
                                </label>
                                <input type="text"
                                       class="form-control custom-input"
                                       id="nombre"
                                       name="nombre"
                                       required
                                       placeholder="Ej: Dead Space / Halo 3">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="categoria" class="form-label text-white-50">
                                    Categoría / Consola
                                </label>
                                <input type="text"
                                       class="form-control custom-input"
                                       id="categoria"
                                       name="categoria"
                                       required
                                       placeholder="Ej: Survival Horror, Xbox, PC">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-white-50">
                                Imagen del juego
                            </label>

                            <!-- OPCIÓN 1: URL -->
                            <input type="url"
                                   id="imgInput"
                                   class="form-control custom-input mb-2"
                                   name="imagen_portada"
                                   placeholder="Pegar URL de imagen">

                            <!-- OPCIÓN 2: ARCHIVO -->
                            <input type="file"
                                   name="imagen"
                                   class="form-control custom-input">
                        </div>

                        <div class="mb-3">
                            <label for="precio" class="form-label text-white-50">
                                Precio (USD / COP)
                            </label>
                            <input type="number"
                                   step="0.01"
                                   min="0"
                                   class="form-control custom-input"
                                   id="precio"
                                   name="precio"
                                   required
                                   placeholder="Ej: 59.99">
                        </div>

                        <div class="mb-4">
                            <label for="descripcion" class="form-label text-white-50">
                                Descripción / Sinopsis
                            </label>
                            <textarea class="form-control custom-input"
                                      id="descripcion"
                                      name="descripcion"
                                      rows="4"
                                      required
                                      placeholder="Ingresa los detalles épicos de la campaña..."></textarea>
                        </div>

                        <button type="submit"
                                class="btn btn-success w-100 btn-lg fw-bold">
                            Desplegar en el Catálogo
                        </button>

                    </form>

                </div>

                <!-- FOOTER -->
                <div class="edit-footer text-center">
                    <p class="mb-0 text-white-50">
                        Acceso restringido. Solo nivel de autorización <strong>Admin</strong>.
                    </p>
                </div>

            </div>

        </div>
    </div>
</div>

<%- include("../partials/footer") %>

<script src="/js/bootstrap.bundle.min.js"></script>

<script>
    const fileInput = document.querySelector('input[name="imagen"]');
    const urlInput = document.getElementById("imgInput");
    const preview = document.getElementById("previewImg");
    fileInput.addEventListener("change", (e) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();

            reader.onload = function (event) {
                preview.src = event.target.result;
            };

            reader.readAsDataURL(file);
        }
    });
    urlInput.addEventListener("input", () => {
        if (urlInput.value.trim() !== "") {
            preview.src = urlInput.value;
        } else {
            preview.src = "/images/default-game.png";
        }
    });
</script>
</body>
</html>
