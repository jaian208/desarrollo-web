<!DOCTYPE html>
<html lang="es">

<%- include("../partials/head") %>

<body class="bg-dark text-light" style="background-color: #121212 !important;">

<%- include("../partials/navbar") %>

<div class="container mt-5 pt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-success border-bottom border-secondary pb-3">
                <i class="bi bi-cart3"></i> Arsenal de Compra
            </h1>
        </div>
    </div>

    <% if (juegos && juegos.length > 0) { %>
        <div class="row">
            <div class="col-lg-8 mb-4">
                <% juegos.forEach(juego => { %>
                    <div class="card mb-3 border-0 shadow-sm" style="background-color: #1b2838;">
                        <div class="row g-0 align-items-center">
                            <div class="col-md-4">
                                <img src="<%= juego.imagen_portada %>" alt="<%= juego.nombre %>" class="img-fluid rounded-start" style="height: 120px; width: 100%; object-fit: cover;">
                            </div>
                            <div class="col-md-5 p-3">
                                <h5 class="card-title fw-bold mb-1"><%= juego.nombre %></h5>
                                <span class="badge bg-primary mb-2"><%= juego.categoria %></span>
                                <p class="card-text text-muted small m-0">Añadido recientemente</p>
                            </div>
                            <div class="col-md-3 p-3 text-end">
                                <h4 class="text-success fw-bold m-0"><%= juego.precio %> COP</h4>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow" style="background-color: #16202d;">
                    <div class="card-body p-4">
                        <h3 class="border-bottom border-secondary pb-2 mb-4 text-light">Resumen</h3>

                        <div class="d-flex justify-content-between mb-3">
                            <span class="fs-5 text-light-50">Total parcial:</span>
                            <span class="fs-5 fw-bold text-light"><%= total %> COP</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4 border-bottom border-secondary pb-3">
                            <span class="fs-5 text-light-50">Impuestos:</span>
                            <span class="fs-5 text-light">0 COP</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4">
                            <h4 class="fw-bold text-light">TOTAL:</h4>
                            <h3 class="fw-bold text-success"><%= total %> COP</h3>
                        </div>

                        <button class="btn btn-success w-100 btn-lg fw-bold mb-3">
                            Proceder al pago
                        </button>

                        <a href="/" class="btn btn-outline-secondary w-100">
                            Seguir comprando
                        </a>
                    </div>
                </div>
            </div>
        </div>

    <% } else { %>
        <div class="row text-center mt-5">
            <div class="col-12">
                <div class="p-5 rounded shadow" style="background-color: #1b2838;">
                    <h2 class="mb-4 text-secondary">Tu carrito está vacío.</h2>
                    <p class="fs-5 mb-4 text-light-50">No has añadido ningún título a tu carrito de compras todavía.</p>
                    <a href="/" class="btn btn-primary btn-lg">Explorar la tienda</a>
                </div>
            </div>
        </div>
    <% } %>

</div>

<%- include("../partials/footer") %>

<script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>