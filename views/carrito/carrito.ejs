<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'Carrito', pageCSS: 'carrito' }) %>

<body class="bg-dark text-light">

<%- include("../partials/navbar") %>

<div class="container mt-5 pt-5">

    <div class="mb-4">
        <h1 class="fw-bold text-light border-bottom pb-3">
            Arsenal de Compra
        </h1>
    </div>

    <% if (juegos && juegos.length > 0) { %>

        <div class="row">
            <div class="col-lg-8">

                <% juegos.forEach(juego => { %>

                    <div class="cart-item mb-3">

                        <img src="<%= juego.imagen_portada %>" class="cart-img">

                        <div class="flex-grow-1 px-3">
                            <h5 class="fw-bold mb-1"><%= juego.nombre %></h5>
                            <span class="badge bg-primary mb-2"><%= juego.categoria %></span>
                            <p class="text-white-50 small m-0">Añadido recientemente</p>
                        </div>

                        <div class="text-end">
                            <h5 class="text-success fw-bold m-0">
                                <%= juego.precio %> COP
                            </h5>
                            <form action="/carrito/eliminar/<%= juego.id %>" method="POST">
                                <button class="btn btn-danger btn-sm">
                                    eliminar
                                </button>
                            </form>
                        </div>

                    </div>

                <% }) %>

            </div>
            <div class="col-lg-4">

                <div class="cart-summary">

                    <h4 class="mb-4 border-bottom pb-2">Resumen</h4>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-white-50">Subtotal</span>
                        <span><%= total %> COP</span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-white-50">Impuestos</span>
                        <span>0 COP</span>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between mb-4">
                        <h5>Total</h5>
                        <h4 class="text-success fw-bold"><%= total %> COP</h4>
                    </div>

                    <form action="/carrito/finalizar" method="POST">
                        <button class="btn btn-success w-100 mb-3 fw-bold">
                            Finalizar compra
                        </button>
                    </form>

                    <a href="/" class="btn btn-outline-light w-100">
                        Seguir comprando
                    </a>

                </div>

            </div>

        </div>

    <% } else { %>

        <!-- CARRITO VACÍO -->
        <div class="empty-cart text-center">

            <h2 class="mb-3">Tu carrito está vacío</h2>

            <p class="text-white-50 mb-4">
                No has añadido juegos aún. Explora la tienda
            </p>

            <a href="/" class="btn btn-primary">
                Ir a la tienda
            </a>

        </div>

    <% } %>

</div>

<%- include("../partials/footer") %>

<script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>