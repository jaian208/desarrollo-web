<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'Perfil', pageCSS: 'perfil' }) %>

<body>

<%- include('../partials/navbar') %>

<div class="container mt-5">

    <!-- HEADER PERFIL -->
    <div class="perfil-header p-4 mb-4 rounded">
        <div class="d-flex align-items-center gap-4">

            <!-- Avatar -->
            <div class="perfil-avatar">
                <img src="<%= user.avatar || '/images/default-avatar.png' %>" alt="avatar">
            </div>

            <!-- Info -->
            <div>
                <h2 class="mb-1"> <%= user.nombre %> </h2>
                <p class="mb-1 text-white-50"><%= user.email %></p>

                <span class="badge-rol <%= user.rol %>">
                    <%= user.rol %>
                </span>
            </div>

        </div>
    </div>

    <!-- CONTENIDO -->
    <div class="row">

        <!-- PANEL IZQUIERDO -->
        <div class="col-md-4 mb-4">
            <div class="perfil-card p-3">
                <h5>Estado de cuenta</h5>
                <p class="<%= user.estado_cuenta ? 'text-success' : 'text-danger' %> fw-bold">
                    <%= user.estado_cuenta ? 'Activa' : 'Inactiva' %>
                </p>
            </div>
        </div>

        <!-- PANEL DERECHO -->
        <div class="col-md-8 mb-4">
            <div class="perfil-card p-3">
                <h5>Resumen</h5>
                <p class="text-white-50">
                    Bienvenido a tu perfil de GameZone. Aquí podrás gestionar tu cuenta y ver tu actividad.
                </p>

                <a href="/logout" class="btn-login mt-3">
                    Cerrar sesión
                </a>
            </div>
        </div>

    </div>

</div>
<!-- JUEGOS DEL USUARIO -->
<div class="perfil-card p-3 mt-4">
    <h5 class="mb-3"> Tu Biblioteca</h5>

    <div class="juegos-grid">

        <% if (juegosbiblioteca && juegosbiblioteca.length > 0) { %>

            <% juegosbiblioteca.forEach(juego => { %>
                <div class="juego-item">
                    <img src="<%= juego.imagen_portada %>"alt="<%= juego.nombre %>">
                    <p><%= juego.nombre %></p>
                </div>
            <% }) %>

        <% } else { %>

                <div class="empty-library text-center py-5">
                    <h5 class="mb-3"> Tu biblioteca está vacía</h5>
                    <p class="text-white-50 mb-4">
                        Aún no tienes juegos. Explora la tienda y añade algunos a tu colección.
                    </p>

                    <a href="/" class="btn-login">
                        Ir a la tienda
                    </a>
                </div>

        <% } %>

    </div>
</div>
<% if (user.rol === 'admin') { %>

    <div class="container mt-4">

        <div class="perfil-card p-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Tus juegos creados</h5>
                <span class="text-white-50 small">
                    <%= juegoscreados.length %> juegos
                </span>
            </div>

            <div class="row g-3">

                <% juegoscreados.forEach(juego => { %>

                    <div class="col-lg-3 col-md-4 col-sm-6">

                        <div class="game-card h-100">

                            <img src="<%= juego.imagen_portada %>"
                                 class="card-img-top"
                                 style="height: 150px; object-fit: cover;">

                            <div class="card-body text-center p-2">

                                <h6 class="text-light text-truncate mb-2">
                                    <%= juego.nombre %>
                                </h6>

                                <a href="/comprar/<%= juego.id %>"
                                   class="btn btn-sm btn-primary w-100 mb-1">
                                    Ver
                                </a>

                                <a href="/edicion/<%= juego.id %>"
                                   class="btn btn-sm btn-warning w-100">
                                    Editar
                                </a>
                                <form action="/juego/eliminar/<%= juego.id %>" method="POST"
                                      onsubmit="return confirm('¿Eliminar <%= juego.nombre %>? Esta acción no se puede deshacer')">

                                    <button class="btn btn-sm btn-danger w-100">
                                        Eliminar
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        </div>

    </div>

<% } %>

<%- include('../partials/footer') %>

<script src="/js/bootstrap.bundle.min.js"></script>

</body>
</html>