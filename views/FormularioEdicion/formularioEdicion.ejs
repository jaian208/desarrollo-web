<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'Editar Juego', pageCSS: 'edicion' }) %>

<body class="bg-dark text-light">

<%- include("../partials/navbar") %>

<div class="container mt-5 pt-4 mb-5">

    <div class="row justify-content-center">

        <div class="col-lg-9">

            <div class="edit-card shadow-lg">
                <div class="edit-header text-center">
                    <h2 class="fw-bold mb-1">Editar Juego</h2>
                    <p class="text-white-50 small m-0">Modifica la información del título</p>
                </div>

                <div class="p-4">
                    <div class="preview-box mb-4 text-center">
                        <img id="previewImg"
                             src="<%= datos.imagen_portada ? datos.imagen_portada : juego.imagen_portada %>"
                             class="img-fluid">
                    </div>
                    <% if (errores && errores.length > 0) { %>
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                <% errores.forEach(error => { %>
                                    <li><%= error.msg %></li>
                                <% }) %>
                            </ul>
                        </div>
                    <% } %>
                    <form action="/edicion/<%= juego.id %>" method="POST" enctype="multipart/form-data">

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-white-50">Título</label>
                                <input type="text"
                                       class="form-control custom-input"
                                       name="nombre"
                                       value="<%= datos.nombre ? datos.nombre : juego.nombre %>">
                            </div>

                            <div class="col-md-6 mb-3">

                                <label class="form-label text-white-50">
                                    Categoría / Consola
                                </label>

                                <select class="form-control custom-input"
                                        name="categoria"
                                        id="categoria">

                                    <option value="">-- Selecciona categoría --</option>

                                    <% categorias.forEach(cat => { %>

                                        <option value="<%= cat %>"
                                                <%= (datos.categoria || juego.categoria) === cat ? 'selected' : '' %>>
                                            <%= cat %>
                                        </option>

                                    <% }) %>

                                </select>

                            </div>

                        </div>


                        <div class="mb-3">

                            <label class="form-label text-white-50">Imagen (URL)</label>
                            <input type="text"
                                   id="imgInput"
                                   class="form-control custom-input"
                                   name="imagen_portada"
                                   value="<%= datos.imagen_portada ? datos.imagen_portada : juego.imagen_portada %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white-50">Subir imagen</label>
                            <input type="file"
                                   name="imagen_portada"
                                   id="fileInput"
                                   class="form-control custom-input"
                                   accept="image/*">
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-white-50">Precio</label>
                            <input type="number"
                                   step="0.01"
                                   class="form-control custom-input"
                                   name="precio"
                                   value="<%= datos.precio ? datos.precio : juego.precio %>">
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-white-50">Descripción</label>
                            <textarea class="form-control custom-input"
                                      name="descripcion"
                                      rows="4"><%= datos.descripcion ? datos.descripcion : juego.descripcion %>
                            </textarea>
                        </div>

                        <button class="btn btn-warning w-100 fw-bold btn-lg save-btn">
                            Guardar Cambios
                        </button>

                        <button type="button"
                                class="btn btn-outline-light w-100 mt-2"
                                onclick="history.back()">
                            Cancelar
                        </button>

                    </form>

                </div>
                <div class="edit-footer text-center">
                    <span class="text-white-50 small">
                        Solo el creador o un administrador pueden modificar este juego
                    </span>
                </div>

            </div>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>

<script src="/js/bootstrap.bundle.min.js"></script>

<script>
    const fileInput = document.getElementById("fileInput");
    const urlInput = document.getElementById("imgInput");
    const preview = document.getElementById("previewImg");

    // Preview desde archivo
    fileInput.addEventListener("change", () => {
        const file = fileInput.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = e => preview.src = e.target.result;
        reader.readAsDataURL(file);
    });

    // Preview desde URL
    urlInput.addEventListener("input", () => {
        preview.src = urlInput.value;
    });
</script>

</body>
</html>