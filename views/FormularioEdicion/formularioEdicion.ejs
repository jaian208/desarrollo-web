<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: 'Editar Juego', pageCSS: 'edicion' }) %>

<body class="bg-dark text-light">

<%- include("../partials/navbar") %>

<div class="container mt-5 pt-4 mb-5">

    <div class="row justify-content-center">

        <div class="col-lg-9">

            <div class="edit-card shadow-lg">
                <div class="edit-header text-center">
                    <h2 class="fw-bold mb-1">Editar Juego</h2>
                    <p class="text-white-50 small m-0">Modifica la información del título</p>
                </div>

                <div class="p-4">
                    <div class="preview-box mb-4 text-center">
                        <img src="<%= juego.imagen_portada %>"
                             id="previewImg"
                             class="preview-img">
                    </div>

                    <form action="/edicion/<%= juego.id %>" method="POST">

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-white-50">Título</label>
                                <input type="text"
                                       class="form-control custom-input"
                                       name="nombre"
                                       value="<%= juego.nombre %>"
                                       required>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label text-white-50">Categoría</label>
                                <input type="text"
                                       class="form-control custom-input"
                                       name="categoria"
                                       value="<%= juego.categoria %>"
                                       required>
                            </div>

                        </div>

                        <div class="mb-3">
                            <label class="form-label text-white-50">Imagen (URL)</label>
                            <input type="text"
                                   id="imgInput"
                                   class="form-control custom-input"
                                   name="imagen_portada"
                                   value="<%= juego.imagen_portada %>"
                                   required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-white-50">Precio</label>
                            <input type="number"
                                   step="0.01"
                                   class="form-control custom-input"
                                   name="precio"
                                   value="<%= juego.precio %>"
                                   required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-white-50">Descripción</label>
                            <textarea class="form-control custom-input"
                                      name="descripcion"
                                      rows="4"
                                      required><%= juego.descripcion %></textarea>
                        </div>

                        <button class="btn btn-warning w-100 fw-bold btn-lg save-btn">
                            Guardar Cambios
                        </button>

                    </form>

                </div>
                <div class="edit-footer text-center">
                    <span class="text-white-50 small">
                        Solo administradores pueden modificar juegos
                    </span>
                </div>

            </div>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>

<script src="/js/bootstrap.bundle.min.js"></script>

<script>
    const input = document.getElementById("imgInput");
    const preview = document.getElementById("previewImg");

    input.addEventListener("input", () => {
        preview.src = input.value;
    });
</script>

</body>
</html>