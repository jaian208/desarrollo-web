<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head', { title: juego.nombre, pageCSS: 'infojuego' }) %>

<body class="bg-dark text-light">

<%- include("../partials/navbar") %>

<div class="container mt-5 pt-4">

    <!-- TÍTULO -->
    <div class="mb-4">
        <h1 class="fw-bold"><%= juego.nombre %></h1>
    </div>

    <div class="row">

        <!-- IZQUIERDA -->
        <div class="col-lg-8 mb-4">

            <!-- IMAGEN -->
            <div class="game-banner mb-4">
                <img src="<%= juego.imagen_portada %>" alt="<%= juego.nombre %>">

                <div class="game-overlay">
                    <h3 class="fw-bold"><%= juego.nombre %></h3>
                </div>
            </div>

            <!-- DESCRIPCIÓN -->
            <div class="p-4 rounded" style="background-color: #1b2838;">
                <h4 class="border-bottom pb-2 mb-3">Acerca de este juego</h4>
                <p class="text-white-50" style="white-space: pre-wrap;">
                    <%= juego.descripcion %>
                </p>
            </div>

        </div>

        <!-- DERECHA -->
        <div class="col-lg-4">

            <div class="game-sidebar shadow">

                <h2 class="text-success mb-4"><%= juego.precio %> COP</h2>

                <a href="/carrito/agregar/<%= juego.id %>"
                   class="btn btn-success w-100 mb-2 fw-bold">
                    Añadir al carrito
                </a>

                <button class="btn btn-outline-light w-100 mb-3">
                    Lista de deseos
                </button>

                <% if (user && (user.id === juego.userId && user.rol === 'admin')) { %>
                    <a href="/edicion/<%= juego.id %>"
                       class="btn btn-warning w-100 fw-bold mb-3 text-dark">
                        Editar Juego
                    </a>
                <% } %>
                <hr>

                <ul class="list-unstyled text-white-50 mt-3">
                    <li class="mb-2">
                        <strong>Categoría:</strong>
                        <span class="badge bg-primary"><%= juego.categoria %></span>
                    </li>
                    <li class="mb-2">
                        <strong>Desarrollador:</strong> GameZone Studios
                    </li>
                    <li class="mb-2">
                        <strong>Fecha:</strong>
                        <%= juego.createdAt.toLocaleDateString() %>
                    </li>
                </ul>

            </div>

            <!-- RESEÑAS -->
            <div class="mt-4 p-3 rounded" style="background-color: #1b2838;">
                <h5 class="border-bottom pb-2">Reseñas</h5>
                <p class="text-white-50 fst-italic mt-2">
                    Aún no hay reseñas. ¡Sé el primero!
                </p>
            </div>

        </div>
    </div>

    <!-- RECOMENDACIONES -->
    <h4 class="mt-5 mb-4 fw-bold"> Recomendaciones</h4>

    <div class="row">

        <% juegosRecomendaciones1.forEach(juego => { %>

            <div class="col-md-3 mb-4">

                <div class="reco-card">

                    <img src="<%= juego.imagen_portada %>"
                         style="height:150px; width:100%; object-fit:cover;">

                    <div class="p-2 text-center">
                        <h6 class="text-light text-truncate">
                            <%= juego.nombre %>
                        </h6>

                        <p class="text-success fw-bold">
                            <%= juego.precio %> COP
                        </p>

                        <a href="/comprar/<%= juego.id %>"
                           class="btn btn-primary btn-sm w-100">
                            Ver juego
                        </a>
                    </div>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<%- include("../partials/footer") %>

<script src="/js/bootstrap.bundle.min.js"></script>

</body>
</html>